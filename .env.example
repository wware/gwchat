# MCP server URL (the kgraph mcpserver SSE endpoint)
MCP_SSE_URL=http://mcpserver:8001/sse

# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Anthropic (supports multiple keys for load balancing)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY_1=sk-ant-...
# ANTHROPIC_API_KEY_2=sk-ant-...
ORCHESTRATOR_MODEL=claude-haiku-4-5-20251001
SYNTHESIS_MODEL=claude-sonnet-4-6

# OpenAI (supports multiple keys for load balancing)
# OPENAI_API_KEY=sk-...
# OPENAI_API_KEY_1=sk-...
# ORCHESTRATOR_MODEL=gpt-4o-mini
# SYNTHESIS_MODEL=gpt-4o

# Ollama (local)
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2

# Domain config file (YAML). Falls back to built-in defaults if unset or missing.
# GWCHAT_CONFIG=/app/config/domain.yaml

# Tuning
MCP_CONNECT_TIMEOUT=25
LLM_MIN_REQUEST_INTERVAL_SECONDS=3.0
LLM_RATE_LIMIT_RETRY_DELAY_SECONDS=20
LLM_SYNTHESIS_HISTORY_TURNS=4
